# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Multi-Tenant AI Commerce OS"
APP_ENV=development          # development | staging | production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Local:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/commerce_os
#
# Free cloud Postgres (Neon / Supabase) — paste connection string, then change prefix:
#   postgresql://...  →  postgresql+asyncpg://...
# Neon example (add ?ssl=require if needed):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxxx.region.aws.neon.tech/neondb?ssl=require

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-
w0uqz2JPvrZ6YjF3wtfBOryO0e9k3M0LmX9oQ_W6DkkL7MRmvBULQn4ZSoQIibkr6TeW
DRF8pa9fPr8f043ChA-7PfJPwAA

# ── Clerk (Auth) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_tcoynzRXCGDoGRTJgvpBKKy8TesZrQZVFqFC1QrhQ4
CLERK_PUBLISHABLE_KEY=pk_test_ZGl2ZXJzZS1iZWRidWctMjMuY2xlcmsuYWNjb3VudHMuZGV2JA
# Same value as "JWKS Public Key" on Clerk → Configure → API keys (right sidebar).
# Optional in dev; leave empty if using DEV_AUTH_BYPASS=true.
CLERK_JWT_KEY=

# Local dev without auth (only when Google + Clerk are unset)
DEV_AUTH_BYPASS=true

# ── Google OAuth (preferred for local sign-in) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
APP_BASE_URL=http://localhost:8000
# Production (replace with your cloud URL):
# GOOGLE_REDIRECT_URI=https://your-app.onrender.com/api/v1/auth/google/callback
# APP_BASE_URL=https://your-app.onrender.com

# ── Jina Reader ───────────────────────────────────────────────────────────────
JINA_API_KEY=jina_...       # optional – omit to use free tier

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://your-app.onrender.com
