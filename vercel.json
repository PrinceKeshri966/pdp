{
  "version": 2,
  "installCommand": "pip install -r requirements-vercel.txt",
  "builds": [
    { "src": "index.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/health", "dest": "index.py" },
    { "src": "/api/(.*)", "dest": "index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
